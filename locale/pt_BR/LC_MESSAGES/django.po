#: life/core/templates/400.html:11
msgid "Bad request"
msgstr "Solicitação inválida"

#: life/core/templates/400.html:12
msgid "The performed request is invalid."
msgstr "A solicitação realizada é inválida."

#: life/core/templates/401.html:11
msgid "Authentication required"
msgstr "Autenticação necessária"

#: life/core/templates/401.html:12
msgid "Please verify your login credentials."
msgstr "Por favor, verifique suas credenciais de login."

#: life/core/templates/403.html:11
msgid "Not Authorized"
msgstr "Não autorizado"

#: life/core/templates/403.html:12
msgid "You don't have permission to view this page."
msgstr "Você não tem permissão para visualizar esta página."

#: life/core/templates/404.html:11
msgid "Page Not Found"
msgstr "Página não encontrada"

#: life/core/templates/404.html:12
msgid ""
"The page you tried to access does not exist. Please check the typed URL or "
"used link."
msgstr ""
"A página que você tentou acessar não existe. Por favor, verifique a URL "
"digitada ou o link utilizado."

#: life/core/templates/500.html:11
msgid "Internal server error"
msgstr "Erro interno do servidor"

#: life/core/templates/500.html:12 life/core/templates/502.html:13
msgid "Please try again or contact your system administrator"
msgstr ""
"Por favor, tente novamente ou entre em contato com o administrador do sistema"

#: life/core/templates/502.html:11
msgid "Service temporarily overloaded"
msgstr "Serviço temporariamente sobrecarregado"

#: life/core/templates/502.html:12
msgid ""
"The server encountered a temporary error and could not complete your request"
msgstr ""
"O servidor encontrou um erro temporário e não pôde concluir sua solicitação"

#: life/core/templates/503.html:11
msgid "Service Unavailable"
msgstr "Serviço indisponível"

#: life/core/templates/503.html:12
msgid ""
"An issue occurred with one or more services required to run the application."
msgstr ""
"Ocorreu um problema com um ou mais serviços necessários para executar a "
"aplicação."

#: life/core/templates/account/account_inactive.html:7
msgid "Account Inactive"
msgstr "Conta inativa"

#: life/core/templates/account/account_inactive.html:9
msgid "This account is inactive."
msgstr "Esta conta está inativa."

#: life/core/templates/account/delete_account.html:10
msgid "Are you sure you want to delete your account?"
msgstr "Tem certeza que deseja excluir sua conta?"

#: life/core/templates/account/delete_account.html:12
msgid "All data points connections to and from your data points will be lost"
msgstr "Todas as conexões com seus dados serão perdidas"

#: life/core/templates/account/delete_account.html:13
msgid "You will lose all your data with us"
msgstr "Você perderá todos os seus dados conosco"

#: life/core/templates/account/delete_account.html:14
msgid "This action is irreversible!"
msgstr "Esta ação é irreversível!"

#: life/core/templates/account/delete_account.html:19
msgid "Yes, delete everything"
msgstr "Sim, excluir tudo"

